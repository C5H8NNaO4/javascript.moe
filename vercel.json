{
  "rewrites": [
    {
      "source": "/Moritz Roessler.vcf",
      "destination": "/public/Moritz Roessler.vcf"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/images/profile.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=6000, stale-while-revalidate=59"
        }
      ]
    },
    {
      "source": "/images/1.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=6000, stale-while-revalidate=59"
        }
      ]
    },
    {
      "source": "/images/wallpaper/20.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=6000, stale-while-revalidate=59"
        }
      ]
    }
  ]
}
